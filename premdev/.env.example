# Copy this to apps/api/.env (dev) or use the install.sh interactive prompts (prod)

NODE_ENV=development
LOG_LEVEL=info
PORT=3001
HOST=0.0.0.0
SECURE_COOKIES=false

PRIMARY_DOMAIN=localhost
PREVIEW_DOMAIN=preview.localhost
DEPLOY_DOMAIN=app.localhost
COOKIE_DOMAIN=

JWT_SECRET=change-me-in-production-please

# Local dev paths (auto-set in dev)
DATA_DIR=./data
WORKSPACES_DIR=./data/workspaces
SQLITE_PATH=./data/premdev.sqlite

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=premdev_net
RUNTIME_IMAGE=premdev/runtime:latest

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_USER_PASSWORD=

# AI providers (any combination — leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# AI output cap per turn (max_tokens sent to the provider).
# Defaults: 4096 (manual) / 8192 (autopilot). Increase if the model still
# truncates large file writes; decrease to save cost on cheap providers.
AI_MAX_TOKENS_DEFAULT=4096
AI_MAX_TOKENS_AUTOPILOT=8192

# Semantic code search (lumen-style, lokal — hemat token AI).
# Set false untuk disable di VPS dengan RAM < 4 GB. Default true.
# Model di-download otomatis dari HuggingFace pertama kali (~470 MB) lalu
# di-cache. Override model name kalau mau pakai yang lebih kecil/multilingual
# berbeda; default-nya support 50+ bahasa termasuk Indonesia + English.
SEMANTIC_SEARCH_ENABLED=true
EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
